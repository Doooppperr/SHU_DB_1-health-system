# 华为云 OCR 配置模板
OCR_PROVIDER=huawei
OCR_USE_MOCK=1

HUAWEI_OCR_ENDPOINT=
HUAWEI_OCR_AK=
HUAWEI_OCR_SK=
HUAWEI_PROJECT_ID=
OCR_API_PATH=/v2/{project_id}/ocr/general-table

